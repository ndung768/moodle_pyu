{{!
    @template theme_phuyen/footer
}}
<footer id="page-footer" class="phuyen-footer bg-white">
    <div class="container-fluid py-4">
        <div class="row">
            <div class="col-md-6">
                <div class="logininfo small text-muted">
                    {{{ output.login_info }}}
                </div>
            </div>
            <div class="col-md-6 text-md-end">
                {{# output.has_popover_links }}
                    {{{ output.page_doc_link }}}
                    {{{ output.services_support_link }}}
                    {{{ output.supportemail }}}
                {{/ output.has_popover_links }}
            </div>
        </div>
        <hr class="my-3">
        <div class="text-center text-muted small">
            {{#str}}poweredbymoodle, core{{/str}}
            {{#output.moodle_release}}
                | {{#str}}version, core{{/str}} {{{ output.moodle_release }}}
            {{/output.moodle_release}}
        </div>
    </div>
    {{{ output.standard_footer_html }}}
    {{{ output.standard_end_of_body_html }}}
</footer>
