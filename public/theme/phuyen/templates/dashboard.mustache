{{!
    @template theme_phuyen/dashboard

    Dashboard layout - stat cards, deadlines, course grid.
}}
<div class="phuyen-dashboard">
    {{#greeting}}
    <div class="phuyen-greeting mb-4">
        <h2 class="h4">{{greeting}}</h2>
    </div>
    {{/greeting}}

    {{#statcards}}
    <div class="row g-3 mb-4 phuyen-stat-cards">
        {{#stats}}
        <div class="col-6 col-lg-3">
            <div class="card phuyen-stat-card h-100">
                <div class="card-body">
                    <div class="phuyen-stat-value">{{value}}</div>
                    <div class="phuyen-stat-label small text-muted">{{label}}</div>
                </div>
            </div>
        </div>
        {{/stats}}
    </div>
    {{/statcards}}

    {{#deadlines}}
    <div class="phuyen-deadlines mb-4">
        <h3 class="h5 mb-3">{{#str}}deadlines, theme_phuyen{{/str}}</h3>
        <ul class="list-group">
            {{#items}}
            <li class="list-group-item phuyen-deadline-item {{status}}">
                <span class="phuyen-deadline-title">{{title}}</span>
                <span class="phuyen-deadline-date">{{date}}</span>
            </li>
            {{/items}}
        </ul>
    </div>
    {{/deadlines}}

    {{#courselist}}
    <div class="phuyen-course-grid">
        <h3 class="h5 mb-3">{{#str}}mycourses, core{{/str}}</h3>
        <div class="row g-3">
            {{#courses}}
            {{> theme_phuyen/coursecard }}
            {{/courses}}
        </div>
    </div>
    {{/courselist}}
</div>
